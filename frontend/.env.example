# Native build-time (read by app.config.ts, baked into the dev build — requires a rebuild to change)
GOOGLE_MAPS_MOBILE_KEY=

# Client runtime (inlined into the JS bundle, no prefix needed at build time — flip and reload)
EXPO_PUBLIC_USE_MOCKS=true
EXPO_PUBLIC_COMPANION_API_BASE_URL=http://localhost:8787
EXPO_PUBLIC_VAPI_PUBLIC_KEY=
EXPO_PUBLIC_VAPI_ASSISTANT_ID=
