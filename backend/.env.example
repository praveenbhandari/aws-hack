PORT=3001
USE_MOCK=false

# API response cache for dev/UI (no external API calls when read/fixtures)
#   off       — always call live APIs
#   record    — call live once, save to guardian/cache/live/
#   read      — serve cache/live/ (fallback: cache/fixtures/)
#   fixtures  — bundled demo data only (no keys needed)
API_CACHE=fixtures

# InsForge — auto-loaded from repo root: ../.env.local + ../.insforge/project.json
INSFORGE_URL=
INSFORGE_ANON_KEY=
INSFORGE_API_KEY=

# Google Maps — server key (Directions, Geocoding, Places API New)
GOOGLE_MAPS_API_KEY=

# Nebius Token Factory
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-fast
NEBIUS_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct

# Crime CSV for ingest script
CRIME_CSV_PATH=../data/Police_Department_Incident_Reports__2018_to_Present_20260619.csv
